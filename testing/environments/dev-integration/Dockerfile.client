FROM golang:1.23-alpine AS build

WORKDIR /src
ENV GOWORK=off

COPY go.work ./
COPY common ./common
COPY client ./client

RUN go build -C client -o /out/client ./cmd/client

FROM node:22-bookworm-slim

ARG CODEX_NPM_VERSION=0.118.0

RUN npm install -g "@openai/codex@${CODEX_NPM_VERSION}"

RUN useradd --system --create-home --home-dir /home/appuser appuser
RUN mkdir -p /home/appuser/.code-agent-gateway && chown -R appuser:appuser /home/appuser
USER appuser
ENV HOME=/home/appuser

COPY --from=build /out/client /usr/local/bin/client

ENTRYPOINT ["/usr/local/bin/client"]
